#!/usr/bin/env bash
# omac — SketchyBar entry point (structure only). Colors live in colors.sh,
# which the theme module will later own. Deployed to ~/.config/sketchybar/.
source "$HOME/.config/sketchybar/colors.sh"

sketchybar --bar height=32 position=top padding_left=8 padding_right=8 color="$BAR_COLOR"

sketchybar --default icon.font="JetBrainsMono Nerd Font:Bold:14.0" \
                     label.font="JetBrainsMono Nerd Font:Bold:14.0" \
                     label.color="$LABEL_COLOR" \
                     padding_left=4 padding_right=4

# Workspace indicators, driven by AeroSpace's aerospace_workspace_change trigger.
# Set label.color per item (not only via --default): on `sketchybar --reload`
# the items already exist, so --default won't recolor them and a theme switch
# would leave stale colors until the next aerospace trigger fires.
sketchybar --add event aerospace_workspace_change
for sid in 1 2 3 4 5 6; do
  sketchybar --add item space.$sid left \
             --set space.$sid label="$sid" label.color="$LABEL_COLOR" \
                   click_script="aerospace workspace $sid" \
                   script="$HOME/.config/sketchybar/plugins/aerospace.sh $sid" \
             --subscribe space.$sid aerospace_workspace_change
done

# Battery on the right (percentage + charge state).
sketchybar --add item battery right \
           --set battery update_freq=120 label.color="$LABEL_COLOR" \
                 script="$HOME/.config/sketchybar/plugins/battery.sh" \
           --subscribe battery power_source_change system_woke

# Clock on the right.
sketchybar --add item clock right \
           --set clock update_freq=10 label.color="$LABEL_COLOR" \
                 script="$HOME/.config/sketchybar/plugins/clock.sh"

sketchybar --update
