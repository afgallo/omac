# Container runtime + tooling. Colima runs the Docker daemon inside a lightweight
# Lima VM — no Docker Desktop, no license, CLI-only (fits omac's no-GUI ethos).
# `lazydocker` (see tuis.Brewfile) is the natural TUI companion.
brew "colima"           # Docker daemon in a Lima VM (Apple Silicon)
brew "docker"           # docker CLI
brew "docker-compose"   # `docker compose` v2 plugin
